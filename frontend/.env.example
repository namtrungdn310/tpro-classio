# Running Next directly on the host (npm run dev / npm run start).
NEXT_INTERNAL_API_URL=http://localhost:8000

# Controls Secure on server-issued auth/flow cookies. Keep false only for
# plain-HTTP localhost. Staging and production must inject true at runtime.
AUTH_COOKIE_SECURE=false

# With Docker Compose, override NEXT_INTERNAL_API_URL to http://backend:8000.
# Staging/production should also use the private service-network backend URL.
