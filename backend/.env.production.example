# Inject production secrets from a secret manager; do not copy staging values.
APP_ENVIRONMENT=production
DATABASE_URL=postgresql+asyncpg://tpro_backend:replace-me@production-db-host:5432/postgres
SECRET_KEY=replace-with-production-signing-secret-at-least-32-characters
AUTH_ENCRYPTION_KEY=replace-with-independent-production-auth-encryption-secret
ALGORITHM=HS256
INTERNAL_TOKEN_ISSUER=tpro-classio-api
INTERNAL_TOKEN_AUDIENCE=tpro-classio-web
ACCESS_TOKEN_EXPIRE_MINUTES=30
SESSION_ABSOLUTE_EXPIRE_DAYS=30
EMAIL_OTP_EXPIRE_SECONDS=600
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=10

FRONTEND_URL=https://classio.example.com
ALLOWED_HOSTS=classio.example.com,backend,127.0.0.1
AUTH_COOKIE_SECURE=true

SUPABASE_URL=https://production-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-production-anon-key
# Backend secret manager only. Never expose this value as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=replace-with-production-service-role-key
OWNER_ADMIN_EMAIL=owner@example.com

GOOGLE_CLIENT_ID=replace-with-production-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-production-google-client-secret
GOOGLE_REDIRECT_URI=https://classio.example.com/auth/google/callback

TOTP_ISSUER=TPRO English
INVITATION_EXPIRE_HOURS=24
ONBOARDING_SESSION_MINUTES=15
LOGIN_MFA_SESSION_MINUTES=5
AVATAR_STORAGE_BUCKET=avatars
AVATAR_SYNC_HOURS=12
