# Staging uses its own Supabase project, Google OAuth client and secrets.
APP_ENVIRONMENT=staging
DATABASE_URL=postgresql+asyncpg://tpro_backend:replace-me@staging-db-host:5432/postgres
SECRET_KEY=replace-with-staging-signing-secret-at-least-32-characters
AUTH_ENCRYPTION_KEY=replace-with-independent-staging-auth-encryption-secret
ALGORITHM=HS256
INTERNAL_TOKEN_ISSUER=tpro-classio-api
INTERNAL_TOKEN_AUDIENCE=tpro-classio-web
ACCESS_TOKEN_EXPIRE_MINUTES=30
SESSION_ABSOLUTE_EXPIRE_DAYS=30
EMAIL_OTP_EXPIRE_SECONDS=600
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=10

FRONTEND_URL=https://staging.classio.example.com
ALLOWED_HOSTS=staging.classio.example.com,backend,127.0.0.1
AUTH_COOKIE_SECURE=true

SUPABASE_URL=https://staging-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-staging-anon-key
# Backend secret manager only. Never expose this value as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=replace-with-staging-service-role-key
OWNER_ADMIN_EMAIL=owner-staging@example.com

GOOGLE_CLIENT_ID=replace-with-staging-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-staging-google-client-secret
GOOGLE_REDIRECT_URI=https://staging.classio.example.com/auth/google/callback

TOTP_ISSUER=TPRO English Staging
INVITATION_EXPIRE_HOURS=24
ONBOARDING_SESSION_MINUTES=15
LOGIN_MFA_SESSION_MINUTES=5
AVATAR_STORAGE_BUCKET=avatars
AVATAR_SYNC_HOURS=12
